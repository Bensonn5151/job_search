# Copy to .env and fill in real values. Never commit .env.

# Job source APIs (both free, both cover Ireland):
#   Jooble    — get a key at https://jooble.org/api/about
#   Careerjet — get an affiliate ID at https://www.careerjet.com/partners/api/
JOOBLE_API_KEY=your_jooble_key_here
CAREERJET_AFFILIATE_ID=your_careerjet_affid_here
JOB_LOCATION=Dublin

# Postgres (see docker-compose.yml)
DATABASE_URL=postgresql://dublin:dublin@localhost:5433/dublin_jobs
