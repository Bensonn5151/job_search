# Copy this file to .env and fill in real values. NEVER commit .env.
# .env is git-ignored; this .example documents which variables exist.

# ─── Adzuna API (Phase 1) — get free keys at https://developer.adzuna.com/ ───
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here

# ─── Search defaults ───
ADZUNA_COUNTRY=ie            # Adzuna country code for Ireland
JOB_LOCATION=Dublin

# ─── Postgres (local) ───
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://localhost:5432/dublin_jobs
