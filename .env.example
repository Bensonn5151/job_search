# Copy to .env and fill in real values. Never commit .env.

# Adzuna API — free keys at https://developer.adzuna.com/
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here
ADZUNA_COUNTRY=ie
JOB_LOCATION=Dublin

# Postgres (see docker-compose.yml)
DATABASE_URL=postgresql://dublin:dublin@localhost:5433/dublin_jobs
